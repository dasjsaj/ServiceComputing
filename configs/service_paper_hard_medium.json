{
  "seed": 1,
  "run_name": "service_paper_hard_medium",
  "output_dir": "artifacts/service_paper",
  "paper": {
    "difficulty": "hard",
    "scale": "medium"
  },
  "env": {
    "env_model": "dual_hop_queue",
    "n_auv": 4,
    "n_usv": 2,
    "n_uav": 2,
    "episode_length": 150,
    "difficulty": "hard",
    "action_mode": "discrete_route",
    "obs_mode": "minimal",
    "reward_mode": "stable_v1",
    "task_arrival_rate": 0.34,
    "initial_tasks_per_auv": 1,
    "queue_capacity": 24,
    "task_data_scale": 0.46,
    "task_cpu_scale": 1.9,
    "auv_cpu_scale": 0.11,
    "usv_cpu_scale": 0.92,
    "uav_cpu_scale": 1.42,
    "shore_cpu_scale": 1.6,
    "backlog_penalty_weight": 0.12,
    "auv_backlog_weight": 1.0,
    "usv_backlog_weight": 0.7,
    "uav_backlog_weight": 0.7,
    "shore_backlog_weight": 0.7,
    "deadline_scale": 2.25,
    "use_mobility_control": false,
    "use_semantic_reward": false,
    "use_route_progress_reward": true,
    "reward_auv_to_usv": 0.08,
    "reward_usv_to_uav": 0.06,
    "reward_usv_to_shore": 0.05,
    "reward_uav_to_shore": 0.04
  },
  "mappo": {
    "total_env_steps": 100000,
    "rollout_steps": 256,
    "eval_episodes": 8,
    "eval_freq": 5000,
    "learning_rate": 0.0001,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_ratio": 0.2,
    "entropy_coef": 0.001,
    "value_loss_coef": 0.5,
    "max_grad_norm": 0.5,
    "update_epochs": 4,
    "minibatch_steps": 128,
    "hidden_dim": 128,
    "anneal_after_positive_eval_drop": true,
    "anneal_factor": 0.2,
    "anneal_min_learning_rate": 0.00001,
    "report_stochastic_eval": true
  }
}
